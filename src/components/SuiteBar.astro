---
// SuiteBar — shared cross-hub nav for the 0-suite. Sits at the very top of every
// hub page (above each hub's own Header) so you can jump between hubs anywhere.
// Uses semantic tokens, so it inherits each route's per-hub theme automatically.
const hubs = [
  { href: '/dev0', label: 'dev0' },
  { href: '/web0', label: 'web0' },
  { href: '/data0', label: 'data0' },
  { href: '/privacy0', label: 'privacy0' },
  { href: '/ui0', label: 'ui0' },
];
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => path === href || path.startsWith(href + '/');
---
<div class="border-b border-rule bg-bg">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 h-9 flex items-center gap-5 text-xs">
    <a
      href="/"
      class={`label hover:text-ink ${path === '/' ? 'text-accent' : ''}`}
    ><span class="text-accent">0</span>-suite</a>
    <span class="text-rule-strong">/</span>
    <nav class="flex items-center gap-4 overflow-x-auto" aria-label="0-suite hubs">
      {hubs.map((h) => (
        <a
          href={h.href}
          aria-current={isActive(h.href) ? 'page' : undefined}
          class={`label hover:text-ink whitespace-nowrap ${isActive(h.href) ? 'text-accent underline underline-offset-4' : ''}`}
        >{h.label}</a>
      ))}
    </nav>
  </div>
</div>
