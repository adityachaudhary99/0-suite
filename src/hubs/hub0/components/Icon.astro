---
import { ICONS } from '../lib/suite';
interface Props { name: string; size?: number; stroke?: number; class?: string; }
const { name, size = 18, stroke = 1.75, class: cls } = Astro.props;
---
<svg
  width={size} height={size} viewBox="0 0 24 24" fill="none"
  stroke="currentColor" stroke-width={stroke} stroke-linecap="round" stroke-linejoin="round"
  class={cls} aria-hidden="true"><Fragment set:html={ICONS[name]} /></svg>
