---
import Icon from './Icon.astro';
import { hubs, stats } from '../lib/suite';

const features = [
  { icon: 'shieldCheck', title: '100% client-side', desc: 'Every tool runs in your browser. Your data is parsed, decoded and computed locally — never sent to a server.' },
  { icon: 'cloudOff', title: 'Nothing uploaded', desc: 'No accounts, no API keys, no telemetry. Open DevTools → Network and watch: zero requests leave the tab.' },
  { icon: 'gitBranch', title: 'Open source', desc: 'The entire suite is MIT-licensed and auditable. Read the code, fork it, or run it yourself offline.' },
];
---
<!-- ============ THE SUITE — premium hub cards w/ clickable tools (single source) ============ -->
<section id="suite" class="max-w-6xl mx-auto w-full px-5 sm:px-8 pt-10 pb-16 scroll-mt-20">
  <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-8" data-reveal>
    <div>
      <p class="label mb-2">The suite</p>
      <h2 class="text-2xl sm:text-3xl text-ink tracking-tight">Four hubs. Twenty-one tools.</h2>
    </div>
    <div class="flex items-center gap-5 text-sm text-muted">
      {stats.map((s) => (
        <span class="metric"><span class="metric-num" data-count={s.num} style={s.accent ? 'color: var(--accent)' : ''}>{s.num}</span>{s.label}</span>
      ))}
    </div>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
    {hubs.map((hub, i) => (
      <article class:list={['pcard spotlight group flex flex-col p-6', hub.cls]} data-reveal
               style={`--hub-accent: ${hub.accent}; --reveal-delay: ${i * 80}ms`}>
        <span class="bk bk-tl"></span><span class="bk bk-tr"></span><span class="bk bk-bl"></span><span class="bk bk-br"></span>
        <div class="flex items-center gap-3.5 mb-4">
          <span class="chip-grad"><Icon name={hub.icon} size={20} /></span>
          <div class="flex flex-col min-w-0">
            <a href={hub.url} rel="noopener" class="text-xl font-bold text-ink leading-tight hover:text-[var(--hub-accent)] transition-colors">{hub.name}</a>
            <span class="label !text-[0.6rem] mt-1">{hub.tagline}</span>
          </div>
          <span class="ml-auto self-start label">{hub.count} tool{hub.count !== '1' ? 's' : ''}</span>
        </div>
        <p class="text-sm text-muted leading-relaxed mb-4">{hub.desc}</p>
        <div class="flex flex-wrap gap-1.5 mb-6">
          {hub.tools.map((t) => (
            <a href={t.href} rel="noopener" class="tool-link">{t.name}<Icon name="arrowUpRight" size={11} stroke={2} /></a>
          ))}
        </div>
        <a href={hub.url} rel="noopener" class="mt-auto inline-flex items-center gap-1.5 text-sm font-semibold w-fit" style={`color: ${hub.accent}`}>
          Open {hub.name}<Icon name="arrowUpRight" size={14} stroke={2.2} />
        </a>
      </article>
    ))}
  </div>
</section>

<!-- ============ BAND (full-bleed) — private by design + features ============ -->
<section class="bg-sunken border-y border-rule">
  <div class="max-w-6xl mx-auto w-full px-5 sm:px-8 py-16 space-y-8">

    <!-- private by design -->
    <div class="pcard spotlight p-7 sm:p-10" data-reveal>
      <span class="bk bk-tl"></span><span class="bk bk-tr"></span><span class="bk bk-bl"></span><span class="bk bk-br"></span>
      <div class="grid lg:grid-cols-[1fr_minmax(0,28rem)] gap-8 lg:gap-12 items-center">
        <div>
          <span class="chip-grad mb-5"><Icon name="lock" size={20} /></span>
          <h2 class="text-2xl sm:text-3xl text-ink tracking-tight">Private by design — and you can prove it.</h2>
          <p class="text-muted mt-3 leading-relaxed max-w-xl">
            Most "online tools" quietly upload your tokens, files and queries to a server. 0-suite never does —
            every computation happens locally in JavaScript and WASM. Don't take our word for it:
          </p>
          <ul class="mt-5 space-y-2.5">
            {['No request ever carries your data', 'Works fully offline once loaded', 'Auditable, MIT-licensed source'].map((t) => (
              <li class="flex items-center gap-2.5 text-sm text-ink-soft">
                <Icon name="check" size={16} stroke={2.4} class="text-accent" />{t}
              </li>
            ))}
          </ul>
        </div>
        <div class="rounded-xl border border-rule bg-bg overflow-hidden shadow-[var(--shadow)]">
          <div class="flex items-center gap-2 px-3.5 py-2.5 border-b border-rule bg-raised">
            <Icon name="search" size={13} />
            <span class="label">DevTools · Network</span>
            <span class="ml-auto flex items-center gap-1.5 label !text-[0.6rem]"><span class="w-1.5 h-1.5 rounded-full bg-[var(--ok)]"></span>0 requests</span>
          </div>
          <div class="px-4 py-4 font-mono text-sm">
            <div class="text-muted"><span class="text-ink">$</span> decode a JWT · scrub a file · run SQL</div>
            <div class="mt-2 flex items-start gap-2 text-[var(--ok)]">
              <Icon name="check" size={15} stroke={2.4} class="mt-0.5" />
              <span>no network activity — everything stayed in your tab<span class="cursor"></span></span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- features 3-up -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
      {features.map((f, i) => (
        <div class="pcard spotlight p-6 bg-bg" data-reveal style={`--reveal-delay: ${i * 90}ms`}>
          <span class="chip-grad mb-4"><Icon name={f.icon} size={20} /></span>
          <h3 class="text-lg font-bold text-ink">{f.title}</h3>
          <p class="text-sm text-muted mt-2 leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<!-- ============ FINAL CTA — glow panel + animated ring ============ -->
<section class="max-w-6xl mx-auto w-full px-5 sm:px-8 pt-16 pb-4">
  <div class="cta-glow ring-anim px-6 sm:px-12 py-16 sm:py-20 text-center" data-reveal>
    <h2 class="text-3xl sm:text-5xl tracking-tight text-ink">Browser tools that <span class="text-grad">respect you.</span></h2>
    <p class="text-muted mt-4 max-w-xl mx-auto leading-relaxed">
      Free, open source, and entirely client-side. No sign-up — just open a tool and go.
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a href="/dev0" class="nbtn shine !px-6 !py-3">Start with dev0<Icon name="arrowRight" size={16} stroke={2} /></a>
      <a href="https://github.com/adityachaudhary99/0-suite" rel="noopener" class="nbtn-ghost !px-6 !py-3"><Icon name="github" size={16} />View source</a>
    </div>
  </div>
</section>
