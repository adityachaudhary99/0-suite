---
import Icon from './Icon.astro';
import { hubs } from '../lib/suite';
---
<footer class="border-t border-rule mt-8">
  <div class="max-w-6xl mx-auto px-5 sm:px-8 py-12">
    <div class="grid grid-cols-2 sm:grid-cols-5 gap-8">
      <div class="col-span-2 sm:col-span-1">
        <a href="/" class="mono font-bold text-ink"><span class="text-accent">0</span>-suite</a>
        <p class="text-sm text-muted mt-3 leading-relaxed max-w-[15rem]">
          Browser-native developer &amp; privacy tools. Everything runs client-side.
        </p>
      </div>
      {hubs.map((hub) => (
        <div>
          <a href={hub.url} class="label !text-ink hover:text-accent transition-colors">{hub.name}</a>
          <ul class="mt-3 space-y-1.5">
            {hub.tools.slice(0, 5).map((t) => (
              <li><a href={t.href} class="text-sm text-muted hover:text-ink transition-colors">{t.name}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <div class="mt-10 pt-6 border-t border-rule flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="label">© 0-suite · all client-side · MIT licensed</p>
      <div class="flex items-center gap-4">
        <a href="https://github.com/adityachaudhary99/0-suite" rel="noopener" aria-label="GitHub"
           class="text-muted hover:text-ink transition-colors"><Icon name="github" size={18} /></a>
        <a href="https://ko-fi.com/thecalendre" rel="noopener" aria-label="Sponsor on Ko-fi"
           class="text-muted hover:text-accent transition-colors"><Icon name="heart" size={18} /></a>
      </div>
    </div>
  </div>
</footer>
