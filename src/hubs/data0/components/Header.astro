---
// data0 is a single-tool hub (the SQL workbench), so there is no tools sub-nav —
// just the brand and the shared shell actions used across the 0-suite.
---
<header class="border-b border-rule">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-5 pb-3 flex items-baseline justify-between gap-4">
    <a href="/data0" class="display text-2xl tracking-tight">data<span class="text-accent">0</span></a>
    <div class="flex items-center gap-5">
      <span class="label hidden sm:inline">SQL on CSV · Parquet · JSON, in your browser</span>
      <button id="theme-toggle" class="label hover:text-ink" aria-label="Toggle theme">◐ theme</button>
      <a href="https://github.com/adityachaudhary99/0-suite" class="label hover:text-ink" rel="noopener">github ↗</a>
      <a href="https://ko-fi.com/thecalendre" class="label hover:text-accent" rel="noopener">♡ sponsor</a>
    </div>
  </div>
</header>
<script>
  import { initThemeToggle } from '../scripts/theme';
  initThemeToggle(document.getElementById('theme-toggle')!);
</script>
