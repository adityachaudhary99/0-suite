---
const tools = [
  { href: '/dev0/jwt', label: 'jwt' }, { href: '/dev0/regex', label: 'regex' },
  { href: '/dev0/cron', label: 'cron' }, { href: '/dev0/base64', label: 'base64' },
  { href: '/dev0/epoch', label: 'epoch' }, { href: '/dev0/json-to-types', label: 'types' },
  { href: '/dev0/jq', label: 'jq' }, { href: '/dev0/erd', label: 'erd' },
  { href: '/dev0/uuid', label: 'uuid' }, { href: '/dev0/cert', label: 'cert' },
  { href: '/dev0/json', label: 'json' }, { href: '/dev0/hash', label: 'hash' },
  { href: '/dev0/diff', label: 'diff' },
];
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<header class="border-b border-rule">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-5 pb-3 flex items-baseline justify-between">
    <a href="/dev0" class="display text-2xl tracking-tight">dev<span class="text-accent">0</span></a>
    <div class="flex items-center gap-5">
      <button id="theme-toggle" class="label hover:text-ink" aria-label="Toggle theme">◐ theme</button>
      <a href="https://github.com/adityachaudhary99/0-suite" class="label hover:text-ink">github ↗</a>
      <a href="https://ko-fi.com/thecalendre" class="label hover:text-accent" rel="noopener">♡ sponsor</a>
    </div>
  </div>
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 pb-3 overflow-x-auto" aria-label="Tools">
    <div class="flex gap-5 min-w-max">
      {tools.map((t) => (
        <a href={t.href}
          aria-current={path === t.href ? 'page' : undefined}
          class={`label hover:text-ink ${path === t.href ? 'text-accent underline underline-offset-4' : ''}`}>
          {t.label}
        </a>
      ))}
    </div>
  </nav>
</header>
<script>
  import { initThemeToggle } from '../scripts/theme';
  initThemeToggle(document.getElementById('theme-toggle')!);
</script>
