---
import Base from '../hubs/hub0/layouts/Base.astro';
import SiteHeader from '../hubs/hub0/components/SiteHeader.astro';
import HeroNotionMarketing from '../hubs/hub0/components/HeroNotionMarketing.astro';
import PageBody from '../hubs/hub0/components/PageBody.astro';
import SiteFooter from '../hubs/hub0/components/SiteFooter.astro';
---
<Base
  title="0-suite - browser tools that respect your privacy"
  description="A suite of browser-native developer and privacy tools. Everything runs client-side: no uploads, no trackers, no API keys."
>
  <SiteHeader />
  <main class="flex-1 w-full">
    <HeroNotionMarketing />
    <PageBody />
  </main>
  <SiteFooter />

  <script>
    import { initThemeToggle } from '../hubs/hub0/scripts/theme';
    import '../hubs/hub0/scripts/animate';
    initThemeToggle(document.getElementById('theme-toggle')!);
  </script>
</Base>
